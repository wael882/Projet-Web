{% extends 'base.html.twig' %}

{% block title %}Admin — Tableau de bord{% endblock %}

{% block content %}
<div class="conteneur">

  <div class="banniere">
    <h1>Tableau de bord</h1>
    <p>Administration Stagio</p>
  </div>

  {% if success %}
    <div class="alert alert-success" style="margin-bottom:1.5rem;">{{ success }}</div>
  {% endif %}
  {% if error %}
    <div class="alert alert-error" style="margin-bottom:1.5rem;">{{ error }}</div>
  {% endif %}

  {# --- Alertes en attente --- #}
  {% if stats.nb_entreprises_en_attente > 0 or stats.nb_modifications_en_attente > 0 or stats.nb_suppressions_en_attente > 0 %}
  <div class="alert-avertissement">
    <p style="font-weight:600;">Actions en attente</p>
    {% if stats.nb_entreprises_en_attente > 0 %}
      <p>
        {{ stats.nb_entreprises_en_attente }} création{{ stats.nb_entreprises_en_attente > 1 ? 's' : '' }} d'entreprise à valider —
        <a href="/admin/entreprises">Traiter</a>
      </p>
    {% endif %}
    {% if stats.nb_modifications_en_attente > 0 %}
      <p>
        {{ stats.nb_modifications_en_attente }} modification{{ stats.nb_modifications_en_attente > 1 ? 's' : '' }} à valider —
        <a href="/admin/modifications">Traiter</a>
      </p>
    {% endif %}
    {% if stats.nb_suppressions_en_attente > 0 %}
      <p>
        {{ stats.nb_suppressions_en_attente }} suppression{{ stats.nb_suppressions_en_attente > 1 ? 's' : '' }} à valider —
        <a href="/admin/suppressions">Traiter</a>
      </p>
    {% endif %}
  </div>
  {% endif %}

  {# --- Chiffres clés --- #}
  <div class="grille-4">
    <div class="stat-card">
      <strong>{{ stats.nb_entreprises }}</strong>
      <p>Entreprises</p>
    </div>
    <div class="stat-card">
      <strong>{{ stats.nb_offres }}</strong>
      <p>Offres actives</p>
    </div>
    <div class="stat-card">
      <strong>{{ stats.nb_etudiants }}</strong>
      <p>Étudiants</p>
    </div>
    <div class="stat-card">
      <strong>{{ stats.nb_candidatures }}</strong>
      <p>Candidatures</p>
    </div>
  </div>

  {# --- Raccourcis --- #}
  <h2 style="margin-bottom:1rem;">Gestion</h2>
  <div class="grille-3">

    <a href="/admin/entreprises" class="carte-gestion">
      <span class="carte-gestion__icone"><i class="fa-solid fa-building" aria-hidden="true"></i></span>
      <span class="carte-gestion__titre">Entreprises</span>
      <span class="carte-gestion__description">Créations, modifications, suppressions</span>
      {% if stats.nb_entreprises_en_attente > 0 %}
        <span class="badge badge--attente">{{ stats.nb_entreprises_en_attente }} en attente</span>
      {% endif %}
    </a>

    <a href="/admin/modifications" class="carte-gestion">
      <span class="carte-gestion__icone"><i class="fa-solid fa-pen" aria-hidden="true"></i></span>
      <span class="carte-gestion__titre">Modifications</span>
      <span class="carte-gestion__description">Demandes de modification d'entreprise</span>
      {% if stats.nb_modifications_en_attente > 0 %}
        <span class="badge badge--attente">{{ stats.nb_modifications_en_attente }} en attente</span>
      {% endif %}
    </a>

    <a href="/admin/suppressions" class="carte-gestion">
      <span class="carte-gestion__icone"><i class="fa-solid fa-trash" aria-hidden="true"></i></span>
      <span class="carte-gestion__titre">Suppressions</span>
      <span class="carte-gestion__description">Demandes de suppression d'entreprise</span>
      {% if stats.nb_suppressions_en_attente > 0 %}
        <span class="badge badge--attente">{{ stats.nb_suppressions_en_attente }} en attente</span>
      {% endif %}
    </a>

    <a href="/offre/creer" class="carte-gestion">
      <span class="carte-gestion__icone"><i class="fa-solid fa-clipboard-list" aria-hidden="true"></i></span>
      <span class="carte-gestion__titre">Créer une offre</span>
      <span class="carte-gestion__description">Publier une nouvelle offre de stage</span>
    </a>

    <a href="/entreprise/inscription" class="carte-gestion">
      <span class="carte-gestion__icone"><i class="fa-solid fa-plus" aria-hidden="true"></i></span>
      <span class="carte-gestion__titre">Ajouter une entreprise</span>
      <span class="carte-gestion__description">Soumettre une nouvelle entreprise</span>
    </a>

    <a href="/admin/pilotes" class="carte-gestion">
      <span class="carte-gestion__icone"><i class="fa-solid fa-chalkboard-user" aria-hidden="true"></i></span>
      <span class="carte-gestion__titre">Pilotes</span>
      <span class="carte-gestion__description">Rechercher et consulter les pilotes</span>
      <span class="badge badge--info">{{ stats.nb_pilotes }} pilote{{ stats.nb_pilotes != 1 ? 's' : '' }}</span>
    </a>

    <a href="/admin/etudiants" class="carte-gestion">
      <span class="carte-gestion__icone"><i class="fa-solid fa-graduation-cap" aria-hidden="true"></i></span>
      <span class="carte-gestion__titre">Étudiants</span>
      <span class="carte-gestion__description">Rechercher, créer, modifier, supprimer</span>
      <span class="badge badge--info">{{ stats.nb_etudiants }} étudiant{{ stats.nb_etudiants != 1 ? 's' : '' }}</span>
    </a>

  </div>

</div>
{% endblock %}
