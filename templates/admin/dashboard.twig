{% extends 'base.html.twig' %}

{% block title %}Admin — Tableau de bord{% endblock %}

{% block content %}
<div style="max-width:960px; margin:0 auto;">

  <div style="background:var(--bleu); border-radius:16px; padding:2rem 2.5rem; margin-bottom:2rem; color:#fff;">
    <h1 style="color:#fff; font-size:1.8rem; margin-bottom:0.25rem;">Tableau de bord</h1>
    <p style="color:rgba(255,255,255,0.65); margin:0;">Administration Stagio</p>
  </div>

  {% if success %}
    <div class="alert alert-success" style="margin-bottom:1.5rem;">{{ success }}</div>
  {% endif %}
  {% if error %}
    <div class="alert alert-error" style="margin-bottom:1.5rem;">{{ error }}</div>
  {% endif %}

  {# --- Alertes en attente --- #}
  {% if stats.nb_entreprises_en_attente > 0 or stats.nb_modifications_en_attente > 0 or stats.nb_suppressions_en_attente > 0 %}
  <div style="background:#fffbeb; border:1px solid #fcd34d; border-left:4px solid #f59e0b; border-radius:10px; padding:1rem 1.5rem; margin-bottom:2rem; display:flex; flex-direction:column; gap:0.5rem;">
    <p style="color:#92400e; font-weight:600; margin:0;">Actions en attente</p>
    {% if stats.nb_entreprises_en_attente > 0 %}
      <p style="margin:0; color:#92400e; font-size:0.9rem;">
        {{ stats.nb_entreprises_en_attente }} création{{ stats.nb_entreprises_en_attente > 1 ? 's' : '' }} d'entreprise à valider —
        <a href="/admin/entreprises" style="color:#d97706; font-weight:600;">Traiter</a>
      </p>
    {% endif %}
    {% if stats.nb_modifications_en_attente > 0 %}
      <p style="margin:0; color:#92400e; font-size:0.9rem;">
        {{ stats.nb_modifications_en_attente }} modification{{ stats.nb_modifications_en_attente > 1 ? 's' : '' }} à valider —
        <a href="/admin/modifications" style="color:#d97706; font-weight:600;">Traiter</a>
      </p>
    {% endif %}
    {% if stats.nb_suppressions_en_attente > 0 %}
      <p style="margin:0; color:#92400e; font-size:0.9rem;">
        {{ stats.nb_suppressions_en_attente }} suppression{{ stats.nb_suppressions_en_attente > 1 ? 's' : '' }} à valider —
        <a href="/admin/suppressions" style="color:#d97706; font-weight:600;">Traiter</a>
      </p>
    {% endif %}
  </div>
  {% endif %}

  {# --- Chiffres clés --- #}
  <div style="display:grid; grid-template-columns:repeat(4,1fr); gap:1rem; margin-bottom:2rem;">
    <div class="stat-card">
      <strong>{{ stats.nb_entreprises }}</strong>
      <p>Entreprises</p>
    </div>
    <div class="stat-card">
      <strong>{{ stats.nb_offres }}</strong>
      <p>Offres actives</p>
    </div>
    <div class="stat-card">
      <strong>{{ stats.nb_etudiants }}</strong>
      <p>Étudiants</p>
    </div>
    <div class="stat-card">
      <strong>{{ stats.nb_candidatures }}</strong>
      <p>Candidatures</p>
    </div>
  </div>

  {# --- Raccourcis --- #}
  <h2 style="margin-bottom:1rem;">Gestion</h2>
  <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:1rem;">

    <a href="/admin/entreprises" style="background:var(--blanc); border:1px solid var(--ligne); border-radius:12px; padding:1.5rem; display:flex; flex-direction:column; gap:0.5rem; text-decoration:none; transition:box-shadow 0.2s;" onmouseover="this.style.boxShadow='0 4px 16px rgba(28,55,91,0.1)'" onmouseout="this.style.boxShadow='none'">
      <span style="font-size:1.6rem;">🏢</span>
      <span style="font-weight:700; color:var(--bleu); font-size:0.95rem;">Entreprises</span>
      <span style="font-size:0.82rem; color:var(--gris);">Créations, modifications, suppressions</span>
      {% if stats.nb_entreprises_en_attente > 0 %}
        <span style="display:inline-block; background:#fef3c7; color:#d97706; font-size:0.78rem; font-weight:600; padding:0.2rem 0.6rem; border-radius:20px; width:fit-content;">{{ stats.nb_entreprises_en_attente }} en attente</span>
      {% endif %}
    </a>

    <a href="/admin/modifications" style="background:var(--blanc); border:1px solid var(--ligne); border-radius:12px; padding:1.5rem; display:flex; flex-direction:column; gap:0.5rem; text-decoration:none; transition:box-shadow 0.2s;" onmouseover="this.style.boxShadow='0 4px 16px rgba(28,55,91,0.1)'" onmouseout="this.style.boxShadow='none'">
      <span style="font-size:1.6rem;">✏️</span>
      <span style="font-weight:700; color:var(--bleu); font-size:0.95rem;">Modifications</span>
      <span style="font-size:0.82rem; color:var(--gris);">Demandes de modification d'entreprise</span>
      {% if stats.nb_modifications_en_attente > 0 %}
        <span style="display:inline-block; background:#fef3c7; color:#d97706; font-size:0.78rem; font-weight:600; padding:0.2rem 0.6rem; border-radius:20px; width:fit-content;">{{ stats.nb_modifications_en_attente }} en attente</span>
      {% endif %}
    </a>

    <a href="/admin/suppressions" style="background:var(--blanc); border:1px solid var(--ligne); border-radius:12px; padding:1.5rem; display:flex; flex-direction:column; gap:0.5rem; text-decoration:none; transition:box-shadow 0.2s;" onmouseover="this.style.boxShadow='0 4px 16px rgba(28,55,91,0.1)'" onmouseout="this.style.boxShadow='none'">
      <span style="font-size:1.6rem;">🗑️</span>
      <span style="font-weight:700; color:var(--bleu); font-size:0.95rem;">Suppressions</span>
      <span style="font-size:0.82rem; color:var(--gris);">Demandes de suppression d'entreprise</span>
      {% if stats.nb_suppressions_en_attente > 0 %}
        <span style="display:inline-block; background:#fef3c7; color:#d97706; font-size:0.78rem; font-weight:600; padding:0.2rem 0.6rem; border-radius:20px; width:fit-content;">{{ stats.nb_suppressions_en_attente }} en attente</span>
      {% endif %}
    </a>

    <a href="/offre/creer" style="background:var(--blanc); border:1px solid var(--ligne); border-radius:12px; padding:1.5rem; display:flex; flex-direction:column; gap:0.5rem; text-decoration:none; transition:box-shadow 0.2s;" onmouseover="this.style.boxShadow='0 4px 16px rgba(28,55,91,0.1)'" onmouseout="this.style.boxShadow='none'">
      <span style="font-size:1.6rem;">📋</span>
      <span style="font-weight:700; color:var(--bleu); font-size:0.95rem;">Créer une offre</span>
      <span style="font-size:0.82rem; color:var(--gris);">Publier une nouvelle offre de stage</span>
    </a>

    <a href="/entreprise/inscription" style="background:var(--blanc); border:1px solid var(--ligne); border-radius:12px; padding:1.5rem; display:flex; flex-direction:column; gap:0.5rem; text-decoration:none; transition:box-shadow 0.2s;" onmouseover="this.style.boxShadow='0 4px 16px rgba(28,55,91,0.1)'" onmouseout="this.style.boxShadow='none'">
      <span style="font-size:1.6rem;">➕</span>
      <span style="font-weight:700; color:var(--bleu); font-size:0.95rem;">Ajouter une entreprise</span>
      <span style="font-size:0.82rem; color:var(--gris);">Soumettre une nouvelle entreprise</span>
    </a>

    <a href="/entreprises" style="background:var(--blanc); border:1px solid var(--ligne); border-radius:12px; padding:1.5rem; display:flex; flex-direction:column; gap:0.5rem; text-decoration:none; transition:box-shadow 0.2s;" onmouseover="this.style.boxShadow='0 4px 16px rgba(28,55,91,0.1)'" onmouseout="this.style.boxShadow='none'">
      <span style="font-size:1.6rem;">🏗️</span>
      <span style="font-weight:700; color:var(--bleu); font-size:0.95rem;">Gérer les entreprises</span>
      <span style="font-size:0.82rem; color:var(--gris);">Créer, modifier, supprimer</span>
    </a>

    <a href="/admin/pilotes" style="background:var(--blanc); border:1px solid var(--ligne); border-radius:12px; padding:1.5rem; display:flex; flex-direction:column; gap:0.5rem; text-decoration:none; transition:box-shadow 0.2s;" onmouseover="this.style.boxShadow='0 4px 16px rgba(28,55,91,0.1)'" onmouseout="this.style.boxShadow='none'">
      <span style="font-size:1.6rem;">👨‍🏫</span>
      <span style="font-weight:700; color:var(--bleu); font-size:0.95rem;">Pilotes</span>
      <span style="font-size:0.82rem; color:var(--gris);">Rechercher et consulter les pilotes</span>
      <span style="display:inline-block; background:var(--carte); color:var(--bleu); font-size:0.78rem; font-weight:600; padding:0.2rem 0.6rem; border-radius:20px; width:fit-content;">{{ stats.nb_pilotes }} pilote{{ stats.nb_pilotes != 1 ? 's' : '' }}</span>
    </a>

    <a href="/admin/etudiants" style="background:var(--blanc); border:1px solid var(--ligne); border-radius:12px; padding:1.5rem; display:flex; flex-direction:column; gap:0.5rem; text-decoration:none; transition:box-shadow 0.2s;" onmouseover="this.style.boxShadow='0 4px 16px rgba(28,55,91,0.1)'" onmouseout="this.style.boxShadow='none'">
      <span style="font-size:1.6rem;">🎓</span>
      <span style="font-weight:700; color:var(--bleu); font-size:0.95rem;">Étudiants</span>
      <span style="font-size:0.82rem; color:var(--gris);">Rechercher, créer, modifier, supprimer</span>
      <span style="display:inline-block; background:var(--carte); color:var(--bleu); font-size:0.78rem; font-weight:600; padding:0.2rem 0.6rem; border-radius:20px; width:fit-content;">{{ stats.nb_etudiants }} étudiant{{ stats.nb_etudiants != 1 ? 's' : '' }}</span>
    </a>

  </div>

</div>
{% endblock %}
