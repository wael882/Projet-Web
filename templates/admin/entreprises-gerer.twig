{% extends 'base.html.twig' %}

{% block title %}Admin — Gestion des entreprises{% endblock %}

{% block content %}
<div class="conteneur">

  <div class="en-tete-page">
    <div>
      <h1 style="margin-bottom:0.2rem;">Gestion des entreprises</h1>
      <p>{{ entreprises|length }} entreprise{{ entreprises|length > 1 ? 's' : '' }} au total</p>
    </div>
    <button onclick="document.getElementById('modal-creer').style.display='flex'" class="btn-principal">+ Créer une entreprise</button>
  </div>

  {% if success %}
    <div class="alert alert-success" style="margin-bottom:1rem;">{{ success }}</div>
  {% endif %}
  {% if error %}
    <div class="alert alert-error" style="margin-bottom:1rem;">{{ error }}</div>
  {% endif %}

  {# Recherche #}
  <form method="GET" class="barre-recherche">
    <input type="text" name="search" value="{{ search }}" placeholder="Rechercher par nom ou ville..."
           data-recherche-live class="saisie">
    <button type="submit" class="btn-principal">Rechercher</button>
    {% if search %}
      <a href="/admin/entreprises/gerer" class="btn-secondaire">Réinitialiser</a>
    {% endif %}
  </form>

  <div id="zone-resultats">
  {% if entreprises is empty %}
    <p>Aucune entreprise trouvée.</p>
  {% else %}
    <div class="liste-verticale" style="gap:0.75rem;">
      {% for e in entreprises %}
        <div class="carte-liste">

          {# Logo ou placeholder #}
          {% if e.logo %}
            <img src="{{ base_url }}{{ e.logo }}" alt="Logo {{ e.nom }}"
                 style="width:52px; height:52px; object-fit:contain; border-radius:8px; border:1px solid var(--ligne); padding:4px; flex-shrink:0;">
          {% else %}
            <div class="logo-initiales">{{ e.nom|slice(0,2)|upper }}</div>
          {% endif %}

          {# Infos #}
          <div style="flex:1; min-width:0;">
            <div style="font-weight:700; font-size:0.97rem;">
              <a href="/entreprise?id={{ e.id_entreprise }}" style="color:var(--bleu);">{{ e.nom }}</a>
            </div>
            <div style="font-size:0.82rem; color:var(--gris); display:flex; gap:1rem; margin-top:0.2rem; flex-wrap:wrap;">
              {% if e.ville %}<span><i class="fa-solid fa-location-dot" aria-hidden="true"></i> {{ e.ville }}</span>{% endif %}
              {% if e.email_contact %}<span><i class="fa-solid fa-envelope" aria-hidden="true"></i> {{ e.email_contact }}</span>{% endif %}
              <span class="badge {% if e.statut == 'approuvee' %}badge--succes{% elseif e.statut == 'en_attente' %}badge--attente{% else %}badge--erreur{% endif %}">
                {{ e.statut|replace({'_': ' '}) }}
              </span>
            </div>
          </div>

          {# Actions #}
          <div style="display:flex; gap:0.5rem; flex-shrink:0;">
            <a href="/admin/entreprise/modifier?id={{ e.id_entreprise }}" class="btn-secondaire">Modifier</a>
            <form method="POST" action="/admin/entreprise/supprimer"
                  onsubmit="return confirm('Supprimer définitivement {{ e.nom }} ?');">
              <input type="hidden" name="id_entreprise" value="{{ e.id_entreprise }}">
              <button type="submit" class="btn-danger">Supprimer</button>
            </form>
          </div>

        </div>
      {% endfor %}
    </div>
  {% endif %}
  </div>

</div>

{# Modal création #}
<div id="modal-creer" class="modal-fond">
  <div class="modal-contenu">
    <div class="modal-en-tete">
      <h2>Créer une entreprise</h2>
      <button type="button" onclick="document.getElementById('modal-creer').style.display='none'" class="btn-fermer">×</button>
    </div>

    <form method="POST" action="/admin/entreprise/creer" enctype="multipart/form-data"
          style="display:flex; flex-direction:column; gap:1rem;">

      <div class="formulaire-colonne">
        <label class="formulaire-label">Nom <span style="color:red;">*</span></label>
        <input type="text" name="nom" required placeholder="Ex : Airbus, Thales..." class="saisie">
      </div>

      <div class="formulaire-colonne">
        <label class="formulaire-label">Description</label>
        <textarea name="description" rows="3" placeholder="Secteur d'activité, missions..."
                  class="saisie" style="resize:vertical;"></textarea>
      </div>

      <div class="formulaire-grille">
        <div>
          <label class="formulaire-label">Email de contact</label>
          <input type="email" name="email_contact" placeholder="contact@entreprise.fr" class="saisie">
        </div>
        <div>
          <label class="formulaire-label">Téléphone</label>
          <input type="tel" name="telephone_contact" placeholder="01 23 45 67 89" class="saisie">
        </div>
      </div>

      <div class="formulaire-grille">
        <div>
          <label class="formulaire-label">Ville</label>
          <input type="text" name="ville" placeholder="Paris, Lyon..." class="saisie">
        </div>
        <div>
          <label class="formulaire-label">Site web</label>
          <input type="url" name="site_web" placeholder="https://..." class="saisie">
        </div>
      </div>

      <div class="formulaire-colonne">
        <label class="formulaire-label">Logo <span class="saisie-aide" style="display:inline;">optionnel — JPG/PNG/WEBP, 2 Mo max</span></label>
        <input type="file" name="logo" accept="image/jpeg,image/png,image/webp" class="saisie">
      </div>

      <div class="formulaire-actions">
        <button type="button" onclick="document.getElementById('modal-creer').style.display='none'"
                class="btn-secondaire">Annuler</button>
        <button type="submit" class="btn-principal">Créer l'entreprise</button>
      </div>

    </form>
  </div>
</div>
{% endblock %}
