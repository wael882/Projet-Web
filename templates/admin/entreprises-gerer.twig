{% extends 'base.html.twig' %}

{% block title %}Admin — Gestion des entreprises{% endblock %}

{% block content %}
<div style="max-width:1000px; margin:0 auto;">

  <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:1.5rem;">
    <div>
      <h1 style="margin-bottom:0.2rem;">Gestion des entreprises</h1>
      <p style="color:var(--gris); margin:0;">{{ entreprises|length }} entreprise{{ entreprises|length > 1 ? 's' : '' }} au total</p>
    </div>
    <button onclick="document.getElementById('modal-creer').style.display='flex'" class="btn-principal">+ Créer une entreprise</button>
  </div>

  {% if success %}
    <div class="alert alert-success" style="margin-bottom:1rem;">{{ success }}</div>
  {% endif %}
  {% if error %}
    <div class="alert alert-error" style="margin-bottom:1rem;">{{ error }}</div>
  {% endif %}

  {# Recherche #}
  <form method="GET" style="margin-bottom:1.5rem; display:flex; gap:0.75rem;">
    <input type="text" name="search" value="{{ search }}" placeholder="Rechercher par nom ou ville..."
           style="flex:1; padding:.6rem .9rem; border:1px solid var(--ligne); border-radius:8px; font-family:inherit;">
    <button type="submit" class="btn-principal">Rechercher</button>
    {% if search %}
      <a href="/admin/entreprises/gerer" style="padding:.6rem 1rem; border:1px solid var(--ligne); border-radius:8px; color:var(--gris); display:flex; align-items:center;">Réinitialiser</a>
    {% endif %}
  </form>

  {# Liste #}
  {% if entreprises is empty %}
    <p style="color:var(--gris);">Aucune entreprise trouvée.</p>
  {% else %}
    <div style="display:flex; flex-direction:column; gap:0.75rem;">
      {% for e in entreprises %}
        <div style="background:var(--blanc); border:1px solid var(--ligne); border-radius:12px; padding:1.25rem 1.5rem; display:flex; align-items:center; gap:1.25rem;">

          {# Logo ou placeholder #}
          {% if e.logo %}
            <img src="{{ base_url }}{{ e.logo }}" alt="Logo {{ e.nom }}"
                 style="width:52px; height:52px; object-fit:contain; border-radius:8px; border:1px solid var(--ligne); padding:4px; flex-shrink:0;">
          {% else %}
            <div style="width:52px; height:52px; background:var(--bleu); border-radius:8px; display:flex; align-items:center; justify-content:center; font-size:1rem; font-weight:800; color:#fff; flex-shrink:0;">
              {{ e.nom|slice(0,2)|upper }}
            </div>
          {% endif %}

          {# Infos #}
          <div style="flex:1; min-width:0;">
            <div style="font-weight:700; font-size:0.97rem;">
              <a href="/entreprise?id={{ e.id_entreprise }}" style="color:var(--bleu); text-decoration:none;">{{ e.nom }}</a>
            </div>
            <div style="font-size:0.82rem; color:var(--gris); display:flex; gap:1rem; margin-top:0.2rem; flex-wrap:wrap;">
              {% if e.ville %}<span><i class="fa-solid fa-location-dot" aria-hidden="true"></i> {{ e.ville }}</span>{% endif %}
              {% if e.email_contact %}<span><i class="fa-solid fa-envelope" aria-hidden="true"></i> {{ e.email_contact }}</span>{% endif %}
              <span style="padding:0.1rem 0.5rem; border-radius:20px; font-size:0.75rem; font-weight:600;
                {% if e.statut == 'approuvee' %}background:#dcfce7; color:#15803d;
                {% elseif e.statut == 'en_attente' %}background:#fef3c7; color:#d97706;
                {% else %}background:#fee2e2; color:#dc2626;{% endif %}">
                {{ e.statut|replace({'_': ' '}) }}
              </span>
            </div>
          </div>

          {# Actions #}
          <div style="display:flex; gap:0.5rem; flex-shrink:0;">
            <a href="/admin/entreprise/modifier?id={{ e.id_entreprise }}"
               style="padding:0.4rem 0.9rem; border:1px solid var(--ligne); border-radius:7px; font-size:0.85rem; font-weight:600; color:var(--bleu); text-decoration:none;">
              Modifier
            </a>
            <form method="POST" action="/admin/entreprise/supprimer"
                  onsubmit="return confirm('Supprimer définitivement {{ e.nom }} ?');">
              <input type="hidden" name="id_entreprise" value="{{ e.id_entreprise }}">
              <button type="submit"
                      style="padding:0.4rem 0.9rem; border:1px solid #fca5a5; border-radius:7px; font-size:0.85rem; font-weight:600; color:#dc2626; background:none; cursor:pointer;">
                Supprimer
              </button>
            </form>
          </div>

        </div>
      {% endfor %}
    </div>
  {% endif %}

</div>

{# Modal création #}
<div id="modal-creer" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.45); z-index:200; align-items:center; justify-content:center; padding:1rem;">
  <div style="background:#fff; border-radius:16px; padding:2rem; width:100%; max-width:560px; max-height:90vh; overflow-y:auto;">
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.5rem;">
      <h2 style="margin:0;">Créer une entreprise</h2>
      <button type="button" onclick="document.getElementById('modal-creer').style.display='none'"
              style="background:none; border:none; font-size:1.4rem; color:var(--gris); cursor:pointer; padding:0;">×</button>
    </div>

    <form method="POST" action="/admin/entreprise/creer" enctype="multipart/form-data"
          style="display:flex; flex-direction:column; gap:1rem;">

      <div style="display:flex; flex-direction:column; gap:0.3rem;">
        <label style="font-weight:600; font-size:0.9rem;">Nom <span style="color:red;">*</span></label>
        <input type="text" name="nom" required placeholder="Ex : Airbus, Thales..."
               style="padding:.6rem .9rem; border:1px solid var(--ligne); border-radius:8px; font-family:inherit;">
      </div>

      <div style="display:flex; flex-direction:column; gap:0.3rem;">
        <label style="font-weight:600; font-size:0.9rem;">Description</label>
        <textarea name="description" rows="3" placeholder="Secteur d'activité, missions..."
                  style="padding:.6rem .9rem; border:1px solid var(--ligne); border-radius:8px; font-family:inherit; resize:vertical;"></textarea>
      </div>

      <div style="display:flex; gap:1rem; flex-wrap:wrap;">
        <div style="flex:1; min-width:180px; display:flex; flex-direction:column; gap:0.3rem;">
          <label style="font-weight:600; font-size:0.9rem;">Email de contact</label>
          <input type="email" name="email_contact" placeholder="contact@entreprise.fr"
                 style="padding:.6rem .9rem; border:1px solid var(--ligne); border-radius:8px; font-family:inherit;">
        </div>
        <div style="flex:1; min-width:180px; display:flex; flex-direction:column; gap:0.3rem;">
          <label style="font-weight:600; font-size:0.9rem;">Téléphone</label>
          <input type="tel" name="telephone_contact" placeholder="01 23 45 67 89"
                 style="padding:.6rem .9rem; border:1px solid var(--ligne); border-radius:8px; font-family:inherit;">
        </div>
      </div>

      <div style="display:flex; gap:1rem; flex-wrap:wrap;">
        <div style="flex:1; min-width:180px; display:flex; flex-direction:column; gap:0.3rem;">
          <label style="font-weight:600; font-size:0.9rem;">Ville</label>
          <input type="text" name="ville" placeholder="Paris, Lyon..."
                 style="padding:.6rem .9rem; border:1px solid var(--ligne); border-radius:8px; font-family:inherit;">
        </div>
        <div style="flex:1; min-width:180px; display:flex; flex-direction:column; gap:0.3rem;">
          <label style="font-weight:600; font-size:0.9rem;">Site web</label>
          <input type="url" name="site_web" placeholder="https://..."
                 style="padding:.6rem .9rem; border:1px solid var(--ligne); border-radius:8px; font-family:inherit;">
        </div>
      </div>

      <div style="display:flex; flex-direction:column; gap:0.3rem;">
        <label style="font-weight:600; font-size:0.9rem;">Logo <span style="color:var(--gris); font-weight:400;">optionnel — JPG/PNG/WEBP, 2 Mo max</span></label>
        <input type="file" name="logo" accept="image/jpeg,image/png,image/webp"
               style="padding:.6rem .9rem; border:1px solid var(--ligne); border-radius:8px; font-family:inherit;">
      </div>

      <div style="display:flex; gap:0.75rem; justify-content:flex-end; margin-top:0.5rem;">
        <button type="button" onclick="document.getElementById('modal-creer').style.display='none'"
                style="padding:.6rem 1.2rem; border:1px solid var(--ligne); border-radius:8px; background:#fff; color:var(--gris); font-family:inherit; cursor:pointer;">
          Annuler
        </button>
        <button type="submit" class="btn-principal">Créer l'entreprise</button>
      </div>

    </form>
  </div>
</div>
{% endblock %}
