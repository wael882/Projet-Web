{% extends 'base.html.twig' %}

{% block title %}Admin - Demandes entreprises{% endblock %}

{% block content %}
<div class="conteneur--md" style="margin-top:2rem;">

  <nav class="onglets-nav">
    <span class="onglets-nav__actif">Créations</span>
    <span class="onglets-nav__separateur">|</span>
    <a href="/admin/modifications" class="onglets-nav__lien">Modifications</a>
    <span class="onglets-nav__separateur">|</span>
    <a href="/admin/suppressions" class="onglets-nav__lien">Suppressions</a>
  </nav>

  <h1 style="margin-bottom:0.25rem;">Demandes de création d'entreprise</h1>
  <p style="margin-bottom:1.5rem;">{{ totalDemandes }} demande{{ totalDemandes > 1 ? 's' : '' }} en attente</p>

  {% if success %}
    <div class="alert alert-success" style="margin-bottom:1rem;">{{ success }}</div>
  {% endif %}
  {% if error %}
    <div class="alert alert-error" style="margin-bottom:1rem;">{{ error }}</div>
  {% endif %}

  {% if demandes is empty %}
    <p>Aucune demande en attente.</p>
  {% else %}
    <div class="liste-verticale liste-verticale--large">
      {% for d in demandes %}
        <div class="carte">

          <div style="display:flex; align-items:center; gap:1rem; margin-bottom:1rem;">
            <div class="logo-initiales">{{ d.nom|slice(0,2)|upper }}</div>
            <div>
              <p style="font-size:1.1rem; font-weight:700; margin:0;">{{ d.nom }}</p>
              <p style="font-size:0.82rem; margin:0;">
                Soumis le {{ d.date_creation|date('d/m/Y à H:i') }}
                {% if d.createur_prenom %}
                  · par <strong>{{ d.createur_prenom }} {{ d.createur_nom }}</strong>
                {% endif %}
              </p>
            </div>
          </div>

          <div style="display:flex; flex-direction:column; gap:0.4rem; margin-bottom:1.25rem;">
            {% if d.description %}
              <p style="margin:0; font-size:0.9rem;">{{ d.description }}</p>
            {% endif %}
            {% if d.ville %}
              <p style="margin:0; font-size:0.85rem;"><i class="fa-solid fa-location-dot" aria-hidden="true"></i> {{ d.ville }}</p>
            {% endif %}
            {% if d.email_contact %}
              <p style="margin:0; font-size:0.85rem;"><i class="fa-solid fa-envelope" aria-hidden="true"></i> {{ d.email_contact }}</p>
            {% endif %}
            {% if d.telephone_contact %}
              <p style="margin:0; font-size:0.85rem;"><i class="fa-solid fa-phone" aria-hidden="true"></i> {{ d.telephone_contact }}</p>
            {% endif %}
            {% if d.site_web %}
              <p style="margin:0; font-size:0.85rem;"><a href="{{ d.site_web }}" target="_blank" style="color:var(--bleu);">{{ d.site_web }}</a></p>
            {% endif %}
          </div>

          <div style="display:flex; gap:0.75rem;">
            <form method="POST" action="/admin/entreprise/approuver">
              <input type="hidden" name="id_entreprise" value="{{ d.id_entreprise }}">
              <button type="submit" class="btn-principal">Approuver</button>
            </form>
            <form method="POST" action="/admin/entreprise/rejeter" onsubmit="return confirm('Rejeter cette demande ?');">
              <input type="hidden" name="id_entreprise" value="{{ d.id_entreprise }}">
              <button type="submit" class="btn-danger">Rejeter</button>
            </form>
          </div>

        </div>
      {% endfor %}
    </div>
  {% endif %}

  {% include 'partials/pagination.html.twig' with {pageCourante: pageCourante, totalPages: totalPages, urlBase: '/admin/entreprises'} %}

</div>
{% endblock %}
