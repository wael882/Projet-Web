{% extends 'base.html.twig' %}

{% block title %}Admin — Modifier {{ etudiant.prenom }} {{ etudiant.nom }}{% endblock %}

{% block content %}
<div style="max-width:600px; margin:0 auto;">

  <a href="/admin/etudiant?id={{ etudiant.id_etudiant }}" style="display:inline-flex; align-items:center; gap:0.4rem; color:var(--gris); font-size:0.88rem; margin-bottom:1.5rem;">← Retour à la fiche</a>

  <div style="background:var(--bleu); border-radius:16px; padding:2rem 2.5rem; margin-bottom:2rem; color:#fff;">
    <h1 style="color:#fff; font-size:1.8rem; margin-bottom:0.25rem;">Modifier l'étudiant</h1>
    <p style="color:rgba(255,255,255,0.65); margin:0;">{{ etudiant.prenom }} {{ etudiant.nom }}</p>
  </div>

  {% if error %}
    <div class="alert alert-error" style="margin-bottom:1.5rem;">{{ error }}</div>
  {% endif %}
  {% if success %}
    <div class="alert alert-success" style="margin-bottom:1.5rem;">{{ success }}</div>
  {% endif %}

  <div style="background:var(--blanc); border:1px solid var(--ligne); border-radius:14px; padding:2rem;">
    <form method="POST" action="/admin/etudiant/modifier">
      <input type="hidden" name="id_etudiant" value="{{ etudiant.id_etudiant }}">

      <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem; margin-bottom:1rem;">
        <div>
          <label style="display:block; font-size:0.85rem; font-weight:600; color:var(--bleu); margin-bottom:0.4rem;">Prénom <span style="color:var(--orange);">*</span></label>
          <input type="text" name="prenom" value="{{ etudiant.prenom }}" required
            style="width:100%; padding:0.65rem 1rem; border:1px solid var(--ligne); border-radius:8px; font-size:0.9rem; font-family:inherit;">
        </div>
        <div>
          <label style="display:block; font-size:0.85rem; font-weight:600; color:var(--bleu); margin-bottom:0.4rem;">Nom <span style="color:var(--orange);">*</span></label>
          <input type="text" name="nom" value="{{ etudiant.nom }}" required
            style="width:100%; padding:0.65rem 1rem; border:1px solid var(--ligne); border-radius:8px; font-size:0.9rem; font-family:inherit;">
        </div>
      </div>

      <div style="margin-bottom:1rem;">
        <label style="display:block; font-size:0.85rem; font-weight:600; color:var(--bleu); margin-bottom:0.4rem;">Email <span style="color:var(--orange);">*</span></label>
        <input type="email" name="email" value="{{ etudiant.email }}" required
          style="width:100%; padding:0.65rem 1rem; border:1px solid var(--ligne); border-radius:8px; font-size:0.9rem; font-family:inherit;">
      </div>

      <div style="margin-bottom:1rem;">
        <label style="display:block; font-size:0.85rem; font-weight:600; color:var(--bleu); margin-bottom:0.4rem;">École</label>
        <input type="text" name="ecole" value="{{ etudiant.ecole }}"
          style="width:100%; padding:0.65rem 1rem; border:1px solid var(--ligne); border-radius:8px; font-size:0.9rem; font-family:inherit;">
      </div>

      <div style="margin-bottom:1rem;">
        <label style="display:block; font-size:0.85rem; font-weight:600; color:var(--bleu); margin-bottom:0.4rem;">Promotion</label>
        <input type="text" name="promotion" value="{{ etudiant.promotion }}"
          style="width:100%; padding:0.65rem 1rem; border:1px solid var(--ligne); border-radius:8px; font-size:0.9rem; font-family:inherit;">
      </div>

      <div style="margin-bottom:1rem;">
        <label style="display:block; font-size:0.85rem; font-weight:600; color:var(--bleu); margin-bottom:0.4rem;">Pilote référent</label>
        <input
          type="text"
          id="champ-pilote"
          list="liste-pilotes"
          placeholder="Taper pour rechercher un pilote…"
          value="{% if etudiant.pilote_prenom %}{{ etudiant.pilote_prenom }} {{ etudiant.pilote_nom }}{% endif %}"
          autocomplete="off"
          style="width:100%; padding:0.65rem 1rem; border:1px solid var(--ligne); border-radius:8px; font-size:0.9rem; font-family:inherit;"
        >
        <datalist id="liste-pilotes">
          <option value="">— Aucun pilote —</option>
          {% for pilote in pilotes %}
            <option value="{{ pilote.prenom }} {{ pilote.nom }}{% if pilote.ecole %} ({{ pilote.ecole }}){% endif %}" data-id="{{ pilote.id_pilote }}"></option>
          {% endfor %}
        </datalist>
        <input type="hidden" name="id_pilote" id="id-pilote-cache" value="{{ etudiant.id_pilote }}">
        <script>
          (function () {
            var champPilote   = document.getElementById('champ-pilote');
            var idPiloteCache = document.getElementById('id-pilote-cache');
            var options       = document.querySelectorAll('#liste-pilotes option');

            champPilote.addEventListener('change', function () {
              var valeurSaisie = champPilote.value.trim();
              var idTrouve     = '';

              options.forEach(function (option) {
                if (option.value === valeurSaisie) {
                  idTrouve = option.getAttribute('data-id') || '';
                }
              });

              idPiloteCache.value = idTrouve;
            });
          })();
        </script>
      </div>

      <div style="margin-bottom:2rem;">
        <label style="display:block; font-size:0.85rem; font-weight:600; color:var(--bleu); margin-bottom:0.4rem;">Nouveau mot de passe</label>
        <input type="password" name="mot_de_passe" minlength="8"
          style="width:100%; padding:0.65rem 1rem; border:1px solid var(--ligne); border-radius:8px; font-size:0.9rem; font-family:inherit;">
        <p style="font-size:0.78rem; color:var(--gris); margin-top:0.3rem;">Laisser vide pour ne pas modifier le mot de passe.</p>
      </div>

      <div style="display:flex; gap:0.75rem; justify-content:flex-end;">
        <a href="/admin/etudiant?id={{ etudiant.id_etudiant }}" style="padding:0.65rem 1.4rem; border:1px solid var(--ligne); border-radius:8px; color:var(--gris); font-size:0.9rem;">Annuler</a>
        <button type="submit" style="padding:0.65rem 1.6rem; background:var(--orange); color:#fff; border:none; border-radius:8px; font-weight:600; cursor:pointer;">Enregistrer</button>
      </div>

    </form>
  </div>

</div>
{% endblock %}
