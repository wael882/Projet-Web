{% extends 'base.html.twig' %}

{% block title %}Admin — Modifier {{ etudiant.prenom }} {{ etudiant.nom }}{% endblock %}

{% block content %}
<div class="conteneur--sm">

  <a href="/admin/etudiant?id={{ etudiant.id_etudiant }}" class="lien-retour">← Retour à la fiche</a>

  <div class="banniere">
    <h1>Modifier l'étudiant</h1>
    <p>{{ etudiant.prenom }} {{ etudiant.nom }}</p>
  </div>

  {% if error %}
    <div class="alert alert-error" style="margin-bottom:1.5rem;">{{ error }}</div>
  {% endif %}
  {% if success %}
    <div class="alert alert-success" style="margin-bottom:1.5rem;">{{ success }}</div>
  {% endif %}

  <div class="formulaire-carte">
    <form method="POST" action="/admin/etudiant/modifier">
      <input type="hidden" name="id_etudiant" value="{{ etudiant.id_etudiant }}">

      <div class="formulaire-grille">
        <div>
          <label class="formulaire-label">Prénom <span style="color:var(--orange);">*</span></label>
          <input type="text" name="prenom" value="{{ etudiant.prenom }}" required class="saisie">
        </div>
        <div>
          <label class="formulaire-label">Nom <span style="color:var(--orange);">*</span></label>
          <input type="text" name="nom" value="{{ etudiant.nom }}" required class="saisie">
        </div>
      </div>

      <div class="formulaire-colonne">
        <label class="formulaire-label">Email <span style="color:var(--orange);">*</span></label>
        <input type="email" name="email" value="{{ etudiant.email }}" required class="saisie">
      </div>

      <div class="formulaire-colonne">
        <label class="formulaire-label">École</label>
        <input type="text" name="ecole" value="{{ etudiant.ecole }}" class="saisie">
      </div>

      <div class="formulaire-colonne">
        <label class="formulaire-label">Promotion</label>
        <input type="text" name="promotion" value="{{ etudiant.promotion }}" class="saisie">
      </div>

      <div class="formulaire-colonne">
        <label class="formulaire-label">Pilote référent</label>
        <input type="text" id="champ-pilote" list="liste-pilotes"
               placeholder="Taper pour rechercher un pilote…"
               value="{% if etudiant.pilote_prenom %}{{ etudiant.pilote_prenom }} {{ etudiant.pilote_nom }}{% endif %}"
               autocomplete="off" class="saisie">
        <datalist id="liste-pilotes">
          <option value="">— Aucun pilote —</option>
          {% for pilote in pilotes %}
            <option value="{{ pilote.prenom }} {{ pilote.nom }}{% if pilote.ecole %} ({{ pilote.ecole }}){% endif %}" data-id="{{ pilote.id_pilote }}"></option>
          {% endfor %}
        </datalist>
        <input type="hidden" name="id_pilote" id="id-pilote-cache" value="{{ etudiant.id_pilote }}">
      </div>

      <div class="formulaire-colonne" style="margin-bottom:2rem;">
        <label class="formulaire-label">Nouveau mot de passe</label>
        <input type="password" name="mot_de_passe" minlength="8" class="saisie">
        <p class="saisie-aide">Laisser vide pour ne pas modifier le mot de passe.</p>
      </div>

      <div class="formulaire-actions">
        <a href="/admin/etudiant?id={{ etudiant.id_etudiant }}" class="btn-secondaire">Annuler</a>
        <button type="submit" class="btn-principal">Enregistrer</button>
      </div>

    </form>
  </div>

</div>
{% endblock %}

{% block scripts %}
{{ parent() }}
<script src="{{ base_url }}js/pages/etudiant-formulaire.js" defer></script>
{% endblock %}
