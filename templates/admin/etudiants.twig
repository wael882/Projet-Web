{% extends 'base.html.twig' %}

{% block title %}Admin — Étudiants{% endblock %}

{% block content %}
<div class="conteneur">

  <div class="banniere banniere--avec-actions">
    <div>
      <h1>Étudiants</h1>
      <p>{{ totalEtudiants }} étudiant{{ totalEtudiants != 1 ? 's' : '' }}{% if recherche %} pour « {{ recherche }} »{% endif %}</p>
    </div>
    <div style="display:flex; align-items:center; gap:1rem;">
      <a href="/admin/etudiant/creer" class="btn-principal">+ Nouvel étudiant</a>
      <a href="/admin" style="color:rgba(255,255,255,0.75); font-size:0.88rem;">← Tableau de bord</a>
    </div>
  </div>

  {% if success %}
    <div class="alert alert-success" style="margin-bottom:1.5rem;">{{ success }}</div>
  {% endif %}
  {% if error %}
    <div class="alert alert-error" style="margin-bottom:1.5rem;">{{ error }}</div>
  {% endif %}

  <form method="GET" action="/admin/etudiants" class="barre-recherche">
    <input type="text" name="search" value="{{ recherche }}"
           placeholder="Rechercher par nom, prénom ou email…"
           data-recherche-live class="saisie">
    <button type="submit" class="btn-bleu">Rechercher</button>
    {% if recherche %}
      <a href="/admin/etudiants" class="btn-secondaire">Effacer</a>
    {% endif %}
  </form>

  <div id="zone-resultats">
  {% if etudiants is empty %}
    <div class="carte-vide">
      <p>Aucun étudiant trouvé{% if recherche %} pour « {{ recherche }} »{% endif %}.</p>
    </div>
  {% else %}
    <div class="liste-verticale">
      {% for etudiant in etudiants %}
      <a href="/admin/etudiant?id={{ etudiant.id_etudiant }}" class="carte-liste">
        <div class="avatar">
          {{ etudiant.prenom|slice(0,1)|upper }}{{ etudiant.nom|slice(0,1)|upper }}
        </div>
        <div style="flex:1; min-width:0;">
          <p style="font-weight:600; color:var(--bleu); margin:0;">{{ etudiant.prenom }} {{ etudiant.nom }}</p>
          <p style="font-size:0.83rem; color:var(--gris); margin:0;">{{ etudiant.email }}{% if etudiant.ecole %} · {{ etudiant.ecole }}{% endif %}</p>
        </div>
        <div style="text-align:right; flex-shrink:0;">
          {% if etudiant.pilote_nom %}
            <p style="font-size:0.8rem; color:var(--gris); margin:0;">Pilote : {{ etudiant.pilote_prenom }} {{ etudiant.pilote_nom }}</p>
          {% else %}
            <p style="font-size:0.8rem; color:var(--gris); margin:0; font-style:italic;">Sans pilote</p>
          {% endif %}
          <p style="font-size:0.8rem; color:var(--gris); margin:0;">{{ etudiant.nb_candidatures }} candidature{{ etudiant.nb_candidatures != 1 ? 's' : '' }}</p>
        </div>
        <span style="color:var(--gris); font-size:1.2rem;">›</span>
      </a>
      {% endfor %}
    </div>
  {% endif %}

  {% set urlBase = recherche ? '/admin/etudiants?search=' ~ recherche : '/admin/etudiants' %}
  {% include 'partials/pagination.html.twig' with {pageCourante: pageCourante, totalPages: totalPages, urlBase: urlBase} %}
  </div>

</div>
{% endblock %}
