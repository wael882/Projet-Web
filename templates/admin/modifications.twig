{% extends 'base.html.twig' %}

{% block title %}Admin - Demandes de modification{% endblock %}

{% block content %}
<div class="conteneur--md" style="margin-top:2rem;">

  <nav class="onglets-nav">
    <a href="/admin/entreprises" class="onglets-nav__lien">Créations</a>
    <span class="onglets-nav__separateur">|</span>
    <span class="onglets-nav__actif">Modifications</span>
    <span class="onglets-nav__separateur">|</span>
    <a href="/admin/suppressions" class="onglets-nav__lien">Suppressions</a>
  </nav>

  <h1 style="margin-bottom:0.25rem;">Demandes de modification</h1>
  <p style="margin-bottom:1.5rem;">{{ demandes|length }} demande{{ demandes|length > 1 ? 's' : '' }} en attente</p>

  {% if success %}
    <div class="alert alert-success" style="margin-bottom:1rem;">{{ success }}</div>
  {% endif %}

  {% if demandes is empty %}
    <p>Aucune demande de modification en attente.</p>
  {% else %}
    <div class="liste-verticale liste-verticale--large">
      {% for d in demandes %}
        <div class="carte">

          <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:1rem;">
            <div>
              <p style="font-size:0.8rem; margin-bottom:0.25rem;">
                Demande de <strong>{{ d.prenom }} {{ d.nom_user }}</strong> — {{ d.date_demande|date('d/m/Y à H:i') }}
              </p>
              <p style="font-size:0.85rem; margin:0;">
                Entreprise actuelle : <a href="/entreprise?id={{ d.id_entreprise }}" style="color:var(--bleu);">{{ d.nom_actuel }}</a>
              </p>
            </div>
          </div>

          <div class="donnees-demande">
            <div>
              <p class="donnee__libelle">Nom proposé</p>
              <p class="donnee__valeur">{{ d.nom }}</p>
            </div>
            {% if d.ville %}
            <div>
              <p class="donnee__libelle">Ville</p>
              <p class="donnee__valeur">{{ d.ville }}</p>
            </div>
            {% endif %}
            {% if d.email_contact %}
            <div>
              <p class="donnee__libelle">Email</p>
              <p class="donnee__valeur">{{ d.email_contact }}</p>
            </div>
            {% endif %}
            {% if d.telephone_contact %}
            <div>
              <p class="donnee__libelle">Téléphone</p>
              <p class="donnee__valeur">{{ d.telephone_contact }}</p>
            </div>
            {% endif %}
            {% if d.site_web %}
            <div style="grid-column:1/-1;">
              <p class="donnee__libelle">Site web</p>
              <a href="{{ d.site_web }}" target="_blank" style="color:var(--bleu);">{{ d.site_web }}</a>
            </div>
            {% endif %}
            {% if d.description %}
            <div style="grid-column:1/-1;">
              <p class="donnee__libelle">Description</p>
              <p class="donnee__valeur" style="font-weight:400; font-size:0.9rem;">{{ d.description }}</p>
            </div>
            {% endif %}
          </div>

          <div style="display:flex; gap:0.75rem;">
            <form method="POST" action="/admin/modification/approuver">
              <input type="hidden" name="id_demande" value="{{ d.id_demande }}">
              <button type="submit" class="btn-principal">Approuver</button>
            </form>
            <form method="POST" action="/admin/modification/rejeter" onsubmit="return confirm('Rejeter cette demande ?');">
              <input type="hidden" name="id_demande" value="{{ d.id_demande }}">
              <button type="submit" class="btn-danger">Rejeter</button>
            </form>
          </div>

        </div>
      {% endfor %}
    </div>
  {% endif %}

</div>
{% endblock %}
