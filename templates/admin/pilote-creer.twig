{% extends 'base.html.twig' %}

{% block title %}Admin — Créer un pilote{% endblock %}

{% block content %}
<div class="conteneur--sm">

  <a href="/admin/pilotes" class="lien-retour">← Retour aux pilotes</a>

  <div class="banniere">
    <h1>Créer un compte pilote</h1>
    <p>Le pilote pourra se connecter immédiatement avec ses identifiants.</p>
  </div>

  {% if error %}
    <div class="alert alert-error" style="margin-bottom:1.5rem;">{{ error }}</div>
  {% endif %}

  <div class="formulaire-carte">
    <form method="POST" action="/admin/pilote/creer">

      <div class="formulaire-grille">
        <div>
          <label class="formulaire-label">Prénom <span style="color:var(--orange);">*</span></label>
          <input type="text" name="prenom" required class="saisie">
        </div>
        <div>
          <label class="formulaire-label">Nom <span style="color:var(--orange);">*</span></label>
          <input type="text" name="nom" required class="saisie">
        </div>
      </div>

      <div class="formulaire-colonne">
        <label class="formulaire-label">Email <span style="color:var(--orange);">*</span></label>
        <input type="email" name="email" required class="saisie">
      </div>

      <div class="formulaire-colonne">
        <label class="formulaire-label">Mot de passe <span style="color:var(--orange);">*</span></label>
        <input type="password" name="mot_de_passe" required minlength="8" class="saisie">
        <p class="saisie-aide">8 caractères minimum.</p>
      </div>

      <div class="formulaire-colonne" style="margin-bottom:2rem;">
        <label class="formulaire-label">École</label>
        <input type="text" name="ecole" class="saisie">
      </div>

      <div class="formulaire-actions">
        <a href="/admin/pilotes" class="btn-secondaire">Annuler</a>
        <button type="submit" class="btn-principal">Créer le compte</button>
      </div>

    </form>
  </div>

</div>
{% endblock %}
