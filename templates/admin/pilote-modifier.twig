{% extends 'base.html.twig' %}

{% block title %}Admin — Modifier {{ pilote.prenom }} {{ pilote.nom }}{% endblock %}

{% block content %}
<div class="conteneur--sm">

  <a href="/admin/pilote?id={{ pilote.id_pilote }}" class="lien-retour">← Retour à la fiche</a>

  <div class="banniere">
    <h1>Modifier le pilote</h1>
    <p>{{ pilote.prenom }} {{ pilote.nom }}</p>
  </div>

  {% if error %}
    <div class="alert alert-error" style="margin-bottom:1.5rem;">{{ error }}</div>
  {% endif %}
  {% if success %}
    <div class="alert alert-success" style="margin-bottom:1.5rem;">{{ success }}</div>
  {% endif %}

  <div class="formulaire-carte">
    <form method="POST" action="/admin/pilote/modifier">
      <input type="hidden" name="id_pilote" value="{{ pilote.id_pilote }}">

      <div class="formulaire-grille">
        <div>
          <label class="formulaire-label">Prénom <span style="color:var(--orange);">*</span></label>
          <input type="text" name="prenom" value="{{ pilote.prenom }}" required class="saisie">
        </div>
        <div>
          <label class="formulaire-label">Nom <span style="color:var(--orange);">*</span></label>
          <input type="text" name="nom" value="{{ pilote.nom }}" required class="saisie">
        </div>
      </div>

      <div class="formulaire-colonne">
        <label class="formulaire-label">Email <span style="color:var(--orange);">*</span></label>
        <input type="email" name="email" value="{{ pilote.email }}" required class="saisie">
      </div>

      <div class="formulaire-colonne">
        <label class="formulaire-label">École</label>
        <input type="text" name="ecole" value="{{ pilote.ecole }}" class="saisie">
      </div>

      <div class="formulaire-colonne" style="margin-bottom:2rem;">
        <label class="formulaire-label">Nouveau mot de passe</label>
        <input type="password" name="mot_de_passe" minlength="8" class="saisie">
        <p class="saisie-aide">Laisser vide pour ne pas modifier le mot de passe.</p>
      </div>

      <div class="formulaire-actions">
        <a href="/admin/pilote?id={{ pilote.id_pilote }}" class="btn-secondaire">Annuler</a>
        <button type="submit" class="btn-principal">Enregistrer</button>
      </div>

    </form>
  </div>

</div>
{% endblock %}
