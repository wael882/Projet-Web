{% extends 'base.html.twig' %}

{% block title %}Admin — {{ pilote.prenom }} {{ pilote.nom }}{% endblock %}

{% block content %}
<div class="conteneur--md">

  <div class="en-tete-page">
    <a href="/admin/pilotes" class="lien-retour" style="margin-bottom:0;">← Retour aux pilotes</a>
    <div style="display:flex; gap:0.75rem;">
      <a href="/admin/pilote/modifier?id={{ pilote.id_pilote }}" class="btn-principal">Modifier</a>
      <form method="POST" action="/admin/pilote/supprimer" onsubmit="return confirm('Supprimer le compte de {{ pilote.prenom }} {{ pilote.nom }} ? Ses étudiants ne seront pas supprimés.');">
        <input type="hidden" name="id_pilote" value="{{ pilote.id_pilote }}">
        <button type="submit" class="btn-danger">Supprimer</button>
      </form>
    </div>
  </div>

  {% if success %}
    <div class="alert alert-success" style="margin-bottom:1.5rem;">{{ success }}</div>
  {% endif %}
  {% if error %}
    <div class="alert alert-error" style="margin-bottom:1.5rem;">{{ error }}</div>
  {% endif %}

  {# Fiche pilote #}
  <div class="carte carte--arrondie" style="margin-bottom:2rem;">
    <div class="profil-entete">
      <div class="avatar avatar--grand">
        {{ pilote.prenom|slice(0,1)|upper }}{{ pilote.nom|slice(0,1)|upper }}
      </div>
      <div>
        <h1 style="font-size:1.5rem; margin-bottom:0.2rem;">{{ pilote.prenom }} {{ pilote.nom }}</h1>
        <p style="margin:0;">{{ pilote.email }}</p>
      </div>
    </div>
    <div class="profil-details">
      <div>
        <p class="profil-detail__libelle">École</p>
        <p class="profil-detail__valeur">{{ pilote.ecole ?: '—' }}</p>
      </div>
      <div>
        <p class="profil-detail__libelle">Étudiants suivis</p>
        <p class="profil-detail__valeur">{{ pilote.nb_etudiants }}</p>
      </div>
      <div>
        <p class="profil-detail__libelle">Membre depuis</p>
        <p class="profil-detail__valeur">{{ pilote.date_creation|date('d/m/Y') }}</p>
      </div>
    </div>
  </div>

  {# Liste des étudiants #}
  <h2 style="margin-bottom:1rem;">Étudiants ({{ etudiants|length }})</h2>
  {% if etudiants is empty %}
    <div class="carte-vide">
      <p>Ce pilote n'a pas encore d'étudiants.</p>
    </div>
  {% else %}
    <div class="liste-verticale" style="gap:0.5rem;">
      {% for etudiant in etudiants %}
      <div class="carte-liste">
        <div style="flex:1; min-width:0;">
          <p style="font-weight:600; color:var(--bleu); margin:0;">{{ etudiant.prenom }} {{ etudiant.nom }}</p>
          <p style="font-size:0.83rem; color:var(--gris); margin:0;">{{ etudiant.email }}</p>
        </div>
        <div style="text-align:right; flex-shrink:0;">
          <p style="font-size:0.83rem; color:var(--gris); margin:0;">{{ etudiant.nb_candidatures }} candidature{{ etudiant.nb_candidatures != 1 ? 's' : '' }}</p>
        </div>
      </div>
      {% endfor %}
    </div>
  {% endif %}

</div>
{% endblock %}
