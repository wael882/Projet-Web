{% extends 'base.html.twig' %}

{% block title %}Admin — Pilotes{% endblock %}

{% block content %}
<div style="max-width:960px; margin:0 auto;">

  <div style="background:var(--bleu); border-radius:16px; padding:2rem 2.5rem; margin-bottom:2rem; color:#fff; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:1rem;">
    <div>
      <h1 style="color:#fff; font-size:1.8rem; margin-bottom:0.25rem;">Pilotes de promotion</h1>
      <p style="color:rgba(255,255,255,0.65); margin:0;">{{ pilotes|length }} pilote{{ pilotes|length != 1 ? 's' : '' }}{% if recherche %} pour « {{ recherche }} »{% endif %}</p>
    </div>
    <div style="display:flex; align-items:center; gap:1rem;">
      <a href="/admin/pilote/creer" style="background:var(--orange); color:#fff; padding:0.6rem 1.2rem; border-radius:8px; font-weight:600; font-size:0.88rem;">+ Nouveau pilote</a>
      <a href="/admin" style="color:rgba(255,255,255,0.75); font-size:0.88rem;">← Tableau de bord</a>
    </div>
  </div>

  {% if success %}
    <div class="alert alert-success" style="margin-bottom:1.5rem;">{{ success }}</div>
  {% endif %}
  {% if error %}
    <div class="alert alert-error" style="margin-bottom:1.5rem;">{{ error }}</div>
  {% endif %}

  {# Barre de recherche #}
  <form method="GET" action="/admin/pilotes" style="display:flex; gap:0.75rem; margin-bottom:1.5rem;">
    <input
      type="text"
      name="search"
      value="{{ recherche }}"
      placeholder="Rechercher par nom, prénom ou email…"
      style="flex:1; padding:0.65rem 1rem; border:1px solid var(--ligne); border-radius:8px; font-size:0.9rem; font-family:inherit;"
    >
    <button type="submit" style="padding:0.65rem 1.4rem; background:var(--bleu); color:#fff; border:none; border-radius:8px; font-weight:600; cursor:pointer;">Rechercher</button>
    {% if recherche %}
      <a href="/admin/pilotes" style="padding:0.65rem 1rem; border:1px solid var(--ligne); border-radius:8px; color:var(--gris); font-size:0.88rem; display:flex; align-items:center;">Effacer</a>
    {% endif %}
  </form>

  {# Liste des pilotes #}
  {% if pilotes is empty %}
    <div style="background:var(--blanc); border:1px solid var(--ligne); border-radius:12px; padding:3rem; text-align:center;">
      <p style="color:var(--gris);">Aucun pilote trouvé{% if recherche %} pour « {{ recherche }} »{% endif %}.</p>
    </div>
  {% else %}
    <div style="display:flex; flex-direction:column; gap:0.6rem;">
      {% for pilote in pilotes %}
      <a href="/admin/pilote?id={{ pilote.id_pilote }}" style="background:var(--blanc); border:1px solid var(--ligne); border-radius:10px; padding:1rem 1.5rem; display:flex; align-items:center; gap:1.5rem; text-decoration:none; transition:box-shadow 0.2s;" onmouseover="this.style.boxShadow='0 4px 12px rgba(28,55,91,0.08)'" onmouseout="this.style.boxShadow='none'">
        <div style="width:40px; height:40px; border-radius:50%; background:var(--carte); display:flex; align-items:center; justify-content:center; font-weight:700; color:var(--bleu); font-size:1rem; flex-shrink:0;">
          {{ pilote.prenom|slice(0,1)|upper }}{{ pilote.nom|slice(0,1)|upper }}
        </div>
        <div style="flex:1; min-width:0;">
          <p style="font-weight:600; color:var(--bleu); margin:0;">{{ pilote.prenom }} {{ pilote.nom }}</p>
          <p style="font-size:0.83rem; color:var(--gris); margin:0;">{{ pilote.email }}{% if pilote.ecole %} · {{ pilote.ecole }}{% endif %}</p>
        </div>
        <div style="text-align:right; flex-shrink:0;">
          <p style="font-weight:700; color:var(--bleu); margin:0;">{{ pilote.nb_etudiants }}</p>
          <p style="font-size:0.8rem; color:var(--gris); margin:0;">étudiant{{ pilote.nb_etudiants != 1 ? 's' : '' }}</p>
        </div>
        <span style="color:var(--gris); font-size:1.2rem;">›</span>
      </a>
      {% endfor %}
    </div>
  {% endif %}

</div>
{% endblock %}
