{% extends 'base.html.twig' %}

{% block title %}Admin — Pilotes{% endblock %}

{% block content %}
<div class="conteneur">

  <div class="banniere banniere--avec-actions">
    <div>
      <h1>Pilotes de promotion</h1>
      <p>{{ totalPilotes }} pilote{{ totalPilotes != 1 ? 's' : '' }}{% if recherche %} pour « {{ recherche }} »{% endif %}</p>
    </div>
    <div style="display:flex; align-items:center; gap:1rem;">
      <a href="/admin/pilote/creer" class="btn-principal">+ Nouveau pilote</a>
      <a href="/admin" style="color:rgba(255,255,255,0.75); font-size:0.88rem;">← Tableau de bord</a>
    </div>
  </div>

  {% if success %}
    <div class="alert alert-success" style="margin-bottom:1.5rem;">{{ success }}</div>
  {% endif %}
  {% if error %}
    <div class="alert alert-error" style="margin-bottom:1.5rem;">{{ error }}</div>
  {% endif %}

  <form method="GET" action="/admin/pilotes" class="barre-recherche">
    <input type="text" name="search" value="{{ recherche }}"
           placeholder="Rechercher par nom, prénom ou email…"
           data-recherche-live class="saisie">
    <button type="submit" class="btn-bleu">Rechercher</button>
    {% if recherche %}
      <a href="/admin/pilotes" class="btn-secondaire">Effacer</a>
    {% endif %}
  </form>

  <div id="zone-resultats">
  {% if pilotes is empty %}
    <div class="carte-vide">
      <p>Aucun pilote trouvé{% if recherche %} pour « {{ recherche }} »{% endif %}.</p>
    </div>
  {% else %}
    <div class="liste-verticale">
      {% for pilote in pilotes %}
      <a href="/admin/pilote?id={{ pilote.id_pilote }}" class="carte-liste">
        <div class="avatar">
          {{ pilote.prenom|slice(0,1)|upper }}{{ pilote.nom|slice(0,1)|upper }}
        </div>
        <div style="flex:1; min-width:0;">
          <p style="font-weight:600; color:var(--bleu); margin:0;">{{ pilote.prenom }} {{ pilote.nom }}</p>
          <p style="font-size:0.83rem; color:var(--gris); margin:0;">{{ pilote.email }}{% if pilote.ecole %} · {{ pilote.ecole }}{% endif %}</p>
        </div>
        <div style="text-align:right; flex-shrink:0;">
          <p style="font-weight:700; color:var(--bleu); margin:0;">{{ pilote.nb_etudiants }}</p>
          <p style="font-size:0.8rem; color:var(--gris); margin:0;">étudiant{{ pilote.nb_etudiants != 1 ? 's' : '' }}</p>
        </div>
        <span style="color:var(--gris); font-size:1.2rem;">›</span>
      </a>
      {% endfor %}
    </div>
  {% endif %}

  {% set urlBase = recherche ? '/admin/pilotes?search=' ~ recherche : '/admin/pilotes' %}
  {% include 'partials/pagination.html.twig' with {pageCourante: pageCourante, totalPages: totalPages, urlBase: urlBase} %}
  </div>

</div>
{% endblock %}
