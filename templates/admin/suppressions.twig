{% extends 'base.html.twig' %}

{% block title %}Admin - Demandes de suppression{% endblock %}

{% block content %}
<div class="conteneur--md" style="margin-top:2rem;">

  <nav class="onglets-nav">
    <a href="/admin/entreprises" class="onglets-nav__lien">Créations</a>
    <span class="onglets-nav__separateur">|</span>
    <a href="/admin/modifications" class="onglets-nav__lien">Modifications</a>
    <span class="onglets-nav__separateur">|</span>
    <span class="onglets-nav__actif">Suppressions</span>
  </nav>

  <h1 style="margin-bottom:0.25rem;">Demandes de suppression</h1>
  <p style="margin-bottom:1.5rem;">{{ demandes|length }} demande{{ demandes|length > 1 ? 's' : '' }} en attente</p>

  {% if success %}
    <div class="alert alert-success" style="margin-bottom:1rem;">{{ success }}</div>
  {% endif %}

  {% if demandes is empty %}
    <p>Aucune demande de suppression en attente.</p>
  {% else %}
    <div class="liste-verticale">
      {% for d in demandes %}
        <div class="carte" style="border-color:#fca5a5;">
          <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1rem;">
            <div>
              <p style="font-weight:700; font-size:1rem; margin:0;">{{ d.nom }}</p>
              <p style="font-size:0.82rem; margin:0;">Demande de <strong>{{ d.prenom }} {{ d.nom_user }}</strong></p>
              {% if d.ville %}<p style="font-size:0.82rem; margin:0;"><i class="fa-solid fa-location-dot" aria-hidden="true"></i> {{ d.ville }}</p>{% endif %}
              {% if d.email_contact %}<p style="font-size:0.82rem; margin:0;"><i class="fa-solid fa-envelope" aria-hidden="true"></i> {{ d.email_contact }}</p>{% endif %}
            </div>
            <a href="/entreprise?id={{ d.id_entreprise }}" style="font-size:0.85rem; color:var(--bleu);">Voir la fiche</a>
          </div>
          <div style="display:flex; gap:0.75rem;">
            <form method="POST" action="/admin/suppression/approuver" onsubmit="return confirm('Supprimer définitivement cette entreprise ?');">
              <input type="hidden" name="id_entreprise" value="{{ d.id_entreprise }}">
              <button type="submit" class="btn-danger">Approuver la suppression</button>
            </form>
            <form method="POST" action="/admin/suppression/rejeter">
              <input type="hidden" name="id_entreprise" value="{{ d.id_entreprise }}">
              <button type="submit" class="btn-principal">Rejeter</button>
            </form>
          </div>
        </div>
      {% endfor %}
    </div>
  {% endif %}

</div>
{% endblock %}
