{% extends 'base.html.twig' %}

{% block title %}Stagio - Accueil{% endblock %}

{% block description %}content="Stagio - Suivie des candidatures"{% endblock %}

{% block styles %}
  {{ parent() }}
  <style>
    .candidature-container {
      margin-top: 2rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    .status-badge {
      padding: 0.5rem 1rem;
      border-radius: 20px;
      font-weight: 600;
      font-size: 0.85rem;
    }
  </style>
{% endblock %}

{% block content %}
  <div class="candidature-container">
  </div>
{% endblock %}

   
