{% extends 'base-index.html.twig' %}

{% block title %}Stagio - {{ entreprise.nom ?? 'Entreprise' }}{% endblock %}

{% block description %}content="Stagio - Détail entreprise"{% endblock %}

{% block styles %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ base_url }}css/pages/entreprise.css" />
{% endblock %}

{% block content %}
  <section id="identite">
    <h1>{{ entreprise.nom }}</h1>
    <p>{{ entreprise.description }}</p>
    <p>Email : {{ entreprise.email_contact }}</p>
    <p>Téléphone : {{ entreprise.telephone_contact }}</p>
  </section>

  <section id="offres">
    <h2>Offres disponibles</h2>
    {% for offre in offresEntreprise %}
      <article>
        <h3>{{ offre.titre }}</h3>
        <p>Durée : {{ offre.duree_stage }} semaines — Rémunération : {{ offre.remuneration_base }} €</p>
        <a href="/offre?id={{ offre.id_offre }}">Voir l'offre</a>
      </article>
    {% else %}
      <p>Aucune offre disponible pour cette entreprise.</p>
    {% endfor %}
  </section>
{% endblock %}
