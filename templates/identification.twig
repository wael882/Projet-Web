{% extends 'base.html.twig' %}

{% block title %}Stagio - Connexion{% endblock %}

{% block description %}content="Stagio - Connectez-vous à votre espace"{% endblock %}

{% block content %}

  <section>
    <form method="POST" action="/identification" novalidate>
      <input type="hidden" name="csrf_token" value="{{ csrf_token }}" />

      <h1>Se connecter</h1>

      {% if success %}
        <p class="msg-success">{{ success }}</p>
      {% endif %}
      {% if erreur %}
        <p class="msg-erreur">{{ erreur }}</p>
      {% endif %}

      <label for="email">Email</label>
      <input
        name="email"
        type="email"
        id="email"
        placeholder="monstage@monstage.fr"
        required
        autocomplete="email"
      />

      <label for="password">Mot de passe</label>
      <input
        name="password"
        type="password"
        id="password"
        required
        autocomplete="current-password"
      />

      <button type="submit">Se connecter</button>

      <p>Pas encore de compte ? <a href="/inscription">S'inscrire</a></p>
    </form>
  </section>

{% endblock %}
