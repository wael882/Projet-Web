<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Stagio - Découvrez notre offre parmi nos entreprises partenaires."
    />

    <title>Stagio - S'identifier/S'inscrire</title>
  </head>
  <body>
    <header>
      <nav>
        <img src="image/logo.webp" alt="Logo Stagio" />
        <a href="{{base_url}}acceuil">Accueil</a>
        <a href="{{base_url}}offre">Offres</a>
        <a href="{{base_url}}a propos">A propos</a>
      </nav>
    </header>

    <main>
      <section id="hero">
        <h1>Trouvez votre stage</h1>
        <p>
          Stagio est la plateforme officielle du CESI pour trouver votre stage.
          Parcourez les offres de nos entreprises partenaires, postulez en
          quelques clics et gérez vos candidatures depuis votre espace
          personnel.
        </p>
        <button>
          <a href="{{ base_url }}inscription">S'inscrire</a>
        </button>
        <button>
          <a href="{{ base_url }}identification">S'identifier</a>
        </button>
      </section>

      <section id="chiffres">
        <h2>Stagio en chiffres</h2>

        <div>
          <strong>+500</strong>
          <p>Offres de stage disponibles</p>
        </div>

        <div>
          <strong>+120</strong>
          <p>Entreprises partenaires</p>
        </div>

        <div>
          <strong>+1200</strong>
          <p>Étudiants inscrits</p>
        </div>

        <div>
          <strong>92%</strong>
          <p>Taux de placement en stage</p>
        </div>
      </section>

      <section id="comment-ca-marche">
        <h2>Comment ça marche ?</h2>

        <div>
          <h3>1. Créez votre profil</h3>
          <p>Inscrivez-vous et complétez votre profil étudiant.</p>
        </div>

        <div>
          <h3>2. Parcourez les offres</h3>
          <p>
            Filtrez les offres par secteur, durée, localisation et type de
            contrat.
          </p>
        </div>

        <div>
          <h3>3. Postulez en un clic</h3>
          <p>Envoyez votre candidature directement depuis la plateforme.</p>
        </div>
      </section>

      <section id="offres">
        <h2>Offres d'emploi</h2>

        <div class="card">
          <img src="" alt="Logo Thales" />
          <h3>Thales</h3>
          <p>Cannes - 06</p>
          <p>Durée du stage : 4 mois</p>
          <a href="{{ base_url }}identification">Voir l'offre</a>
          <!-- dois etre connecté pour acceder a l'ofre -->
        </div>

        <div class="card">
          <img src="" alt="Logo Aibus" />
          <h3>Aibus</h3>
          <p>Paris - 94</p>
          <p>Durée du stage : 6 mois</p>
          <a href="{{ base_url }}identification">Voir l'offre</a>
          <!-- dois etre connecté pour acceder a l'ofre -->
        </div>

        <div class="card">
          <img src="" alt="Logo Naval Group" />
          <h3>Naval Group</h3>
          <p>Nantes - 44</p>
          <p>Durée du stage : 3 mois</p>
         <a href="{{ base_url }}identification">Voir l'offre</a>
          <!-- dois etre connecté pour acceder a l'ofre -->
        </div>
      </section>
    </main>

    <footer>
      <table>
        <tr>
          <td>&copy; 2024 Stagio - CESI. Tous droits réservés.</td>
        </tr>
        <tr>
          <td><a href="{{base_url}}mention-legal">Mentions légales</a></td>
          <td><a href="{{base_url}}offre">Offres</a></td>
          <td><a href="{{base_url}}contact">Contact</a></td>
          <td><a href="{{base_url}}entreprise">Entreprises</a></td>
        </tr>
      </table>
    </footer>
  </body>
</html>
