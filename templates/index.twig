{% extends 'base-index.html.twig' %}

{% block title %}Stagio - Accueil{% endblock %}

{% block styles %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ base_url }}css/pages/index.css" />
{% endblock %}

{% block content %}

  <section id="hero">
    <h1>Décrochez<br><span class="accent">votre stage.</span></h1>
    <p>
      Stagio aide les étudiants du CESI à trouver leur stage.
      Parcourez les offres, postulez et gérez vos candidatures
      depuis un seul endroit.
    </p>
    <div class="hero-btns">
      <a href="{{ base_url }}inscription" class="btn-principal">S'inscrire gratuitement</a>
      <a href="{{ base_url }}identification" class="btn-secondaire">Déjà un compte ?</a>
    </div>
  </section>

  <section id="chiffres">
    <h2>Stagio en chiffres</h2>
    <div class="chiffres-grid">
      <div>
        <strong>+500</strong>
        <p>offres disponibles</p>
      </div>
      <div>
        <strong>+120</strong>
        <p>entreprises partenaires</p>
      </div>
      <div>
        <strong>+1200</strong>
        <p>étudiants inscrits</p>
      </div>
      <div>
        <strong>92%</strong>
        <p>taux de placement</p>
      </div>
    </div>
  </section>

  <section id="comment-ca-marche">
    <h2>Comment ça marche ?</h2>
    <div class="timeline">
      <div class="timeline-line"></div>
      <div class="timeline-step">
        <div class="timeline-dot">1</div>
        <h3>Créez votre profil</h3>
        <p>Inscrivez-vous et renseignez vos informations étudiantes.</p>
      </div>
      <div class="timeline-step">
        <div class="timeline-dot">2</div>
        <h3>Parcourez les offres</h3>
        <p>Filtrez par secteur, durée, localisation et type de contrat.</p>
      </div>
      <div class="timeline-step">
        <div class="timeline-dot">3</div>
        <h3>Postulez</h3>
        <p>Envoyez votre candidature directement depuis la plateforme.</p>
      </div>
    </div>
  </section>

{% endblock %}
