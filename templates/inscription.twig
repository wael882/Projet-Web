{% extends 'base.html.twig' %}

{% block title %}Stagio - S'inscrire{% endblock %}

{% block description %}content="Stagio - Crée un compte"{% endblock %}

{% block content %}

    <main>
      <section>
        <form action="">
          <h1>S'inscrire</h1>
          <span>Nom</span><br />
          <input type="text" id="nom" placeholder="Nom" /><br />
          <span>Prenom</span><br />
          <input type="text" id="prenom" placeholder="Prénom" /><br />
          <span>Ecole</span><br />
          <input type="text" id="ecole" placeholder="Ecole" /><br />
          <span>Email</span><br />
          <input
            type="email"
            id="email"
            placeholder="monstage@monstage.fr"
          /><br />
          <span>Mot de passe</span><br />
          <input type="password" id="password" /><br />
          <button type="submit">S'inscrire</button>
        </form>
      </section>
    </main>


{% endblock %}