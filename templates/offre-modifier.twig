{% extends 'base.html.twig' %}

{% block title %}Stagio - Modifier une offre{% endblock %}

{% block description %}content="Stagio - Modifier une offre de stage"{% endblock %}

{% block styles %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ base_url }}css/pages/postuler.css" />
{% endblock %}

{% block content %}

  <main class="postuler-container">
    <div class="postuler-card">

      <div class="postuler-header">
        <h1>Modifier l'offre de stage</h1>
      </div>

      {% if error %}
        <p class="alert alert-error">{{ error }}</p>
      {% endif %}

      <form method="POST" action="/offre/modifier" enctype="multipart/form-data" class="postuler-form">
        <input type="hidden" name="id_offre" value="{{ offre.id_offre }}">

        <div class="form-group">
          <label for="saisie-entreprise">Entreprise</label>
          <input type="text" id="saisie-entreprise" list="liste-entreprises"
                 value="{{ offre.nom_entreprise }}" autocomplete="off" required>
          <datalist id="liste-entreprises">
            {% for entreprise in entreprises %}
              <option value="{{ entreprise.nom }}" data-id="{{ entreprise.id_entreprise }}"></option>
            {% endfor %}
          </datalist>
          <input type="hidden" id="id_entreprise" name="id_entreprise" value="{{ offre.id_entreprise }}">
        </div>

        <div class="form-group">
          <label for="titre">Titre du poste</label>
          <input type="text" id="titre" name="titre"
                 value="{{ offre.titre }}" required>
        </div>

        <div class="form-group">
          <label for="description">Description</label>
          <textarea id="description" name="description" rows="8" required>{{ offre.description }}</textarea>
        </div>

        <div class="form-group">
          <label for="remuneration_base">Rémunération de base (€/an) <span class="hint">optionnel</span></label>
          <input type="number" id="remuneration_base" name="remuneration_base"
                 value="{{ offre.remuneration_base }}" min="0" step="0.01">
        </div>

        <div class="form-group">
          <label for="date_offre">Date de début du stage <span class="hint">optionnel</span></label>
          <input type="date" id="date_offre" name="date_offre"
                 value="{{ offre.date_offre ? offre.date_offre|date('Y-m-d') : '' }}">
        </div>

        <div class="form-group">
          <label for="photo">Nouvelle photo <span class="hint">optionnel — laissez vide pour conserver l'actuelle</span></label>
          {% if offre.photo %}
            <img src="{{ base_url }}{{ offre.photo }}" alt="Photo actuelle" style="max-width:200px;display:block;margin-bottom:8px;">
          {% endif %}
          <input type="file" id="photo" name="photo" accept="image/jpeg,image/png,image/webp">
        </div>

        <div class="form-group">
          <label>Compétences requises <span class="hint">optionnel</span></label>

          {# Compétences déjà associées à l'offre #}
          <div class="tags-nouvelles-competences" id="tags-competences-existantes">
            {% for comp in competences %}
              <span class="tag-competence tag-competence-existante">
                <span>{{ comp }}</span>
                <input type="hidden" name="nouvelles_competences[]" value="{{ comp }}">
                <button type="button" onclick="this.parentElement.remove(); mettreAJourRecapitulatif();" title="Retirer">×</button>
              </span>
            {% endfor %}
          </div>

          <div class="nouvelle-competence-zone" style="margin-top:8px;">
            <input type="text" id="saisie-competence" placeholder="Ajouter une compétence..." autocomplete="off">
            <button type="button" class="btn-ajouter-competence" onclick="ajouterCompetence()">Ajouter</button>
          </div>
          <div class="tags-nouvelles-competences" id="tags-nouvelles-competences"></div>

          <div class="recapitulatif-competences" id="recapitulatif-competences">
            <div class="recapitulatif-entete">
              <span class="recapitulatif-titre">Compétences</span>
              <span class="recapitulatif-compteur" id="compteur-competences">{{ competences|length }}</span>
            </div>
            <p class="recapitulatif-vide" id="recapitulatif-vide" {% if competences|length > 0 %}style="display:none"{% endif %}>Aucune compétence ajoutée pour le moment.</p>
            <div class="recapitulatif-liste" id="recapitulatif-liste"></div>
          </div>
        </div>

        <div class="form-actions">
          <a href="/offre?id={{ offre.id_offre }}" class="btn-annuler">Annuler</a>
          <button type="submit" class="btn-postuler">Enregistrer les modifications</button>
        </div>

      </form>

      <script>
        // Résolution entreprise → id
        const cartEntreprises = {};
        document.querySelectorAll('#liste-entreprises option').forEach(opt => {
          cartEntreprises[opt.value.toLowerCase()] = opt.dataset.id;
        });

        document.getElementById('saisie-entreprise').addEventListener('input', function() {
          const id = cartEntreprises[this.value.trim().toLowerCase()] ?? '';
          document.getElementById('id_entreprise').value = id;
        });

        document.querySelector('form').addEventListener('submit', function(e) {
          const id = document.getElementById('id_entreprise').value;
          if (!id) {
            e.preventDefault();
            document.getElementById('saisie-entreprise').setCustomValidity('Veuillez choisir une entreprise de la liste.');
            document.getElementById('saisie-entreprise').reportValidity();
          } else {
            document.getElementById('saisie-entreprise').setCustomValidity('');
          }
        });

        function ajouterCompetence() {
          const saisie  = document.getElementById('saisie-competence');
          const libelle = saisie.value.trim();
          if (!libelle) return;

          const dejaSaisie = [...document.querySelectorAll('.tag-competence span')].map(s => s.textContent.toLowerCase());
          if (dejaSaisie.includes(libelle.toLowerCase())) {
            saisie.value = '';
            return;
          }

          const conteneur = document.getElementById('tags-nouvelles-competences');
          const tag = document.createElement('span');
          tag.className = 'tag-competence';
          tag.innerHTML = `<span>${libelle}</span><input type="hidden" name="nouvelles_competences[]" value="${libelle}"><button type="button" onclick="this.parentElement.remove(); mettreAJourRecapitulatif();" title="Retirer">×</button>`;
          conteneur.appendChild(tag);
          saisie.value = '';
          saisie.focus();
          mettreAJourRecapitulatif();
        }

        function mettreAJourRecapitulatif() {
          const tags    = [...document.querySelectorAll('.tag-competence span')];
          const liste   = document.getElementById('recapitulatif-liste');
          const vide    = document.getElementById('recapitulatif-vide');
          const compteur = document.getElementById('compteur-competences');

          liste.innerHTML  = '';
          compteur.textContent = tags.length;

          if (tags.length === 0) {
            vide.style.display = 'block';
          } else {
            vide.style.display = 'none';
            tags.forEach((tag, index) => {
              const ligne = document.createElement('div');
              ligne.className = 'recapitulatif-ligne';
              ligne.innerHTML = `<span class="recapitulatif-numero">${index + 1}</span><span class="recapitulatif-nom">${tag.textContent}</span>`;
              liste.appendChild(ligne);
            });
          }
        }

        document.getElementById('saisie-competence').addEventListener('keydown', function(e) {
          if (e.key === 'Enter') { e.preventDefault(); ajouterCompetence(); }
        });

        // Initialise le récapitulatif avec les compétences existantes
        mettreAJourRecapitulatif();
      </script>

    </div>
  </main>

{% endblock %}
