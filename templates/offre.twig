{% extends 'base.html.twig' %}

{% block title %}Stagio - Accueil{% endblock %}

{% block description %}content="Stagio - Acceuil"{% endblock %}

{% block styles %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ base_url }}css/pages/offre.css" />
{% endblock %}

{% block content %}
  <div class="offer-detail">
    <div class="offer-header">
      {{ offre.titre }}
      {{ offre.description }}
      {{ offre.date_offre }}
      {{ offre.duree_stage }}
      <a href="/entreprise?id={{ offre.id_entreprise }}">{{ offre.nom_entreprise }}</a>
      {{ offre.email_contact }}
      {{ offre.telephone_contact }}
    </div>
    <div class="apply-section">
      {% if offre.id_offre in favorisIds %}
      <form method="POST" action="{{ base_url }}favoris/supprimer">
          <input type="hidden" name="id_offre" value="{{ offre.id_offre }}">
          <button type="submit">&#10084;</button>
      </form>
      {% else %}
      <form method="POST" action="{{ base_url }}favoris">
          <input type="hidden" name="id_offre" value="{{ offre.id_offre }}">
          <button type="submit">&#9825;</button>
      </form>
      {% endif %}
    </div>
  </div>
{% endblock %}
