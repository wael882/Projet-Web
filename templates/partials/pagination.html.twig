{#
  Partial de pagination réutilisable.
  Variables attendues :
    - pageCourante  : numéro de la page actuelle
    - totalPages    : nombre total de pages
    - urlBase       : URL de base sans paramètre page (ex: "/admin/pilotes?search=foo")
                      Si urlBase contient déjà "?", on ajoute "&page=X", sinon "?page=X"
#}
{% if totalPages > 1 %}
  {% set separateur = '?' in urlBase ? '&' : '?' %}
  <nav class="pagination-nav">
    {% if pageCourante > 1 %}
      <a href="{{ urlBase }}{{ separateur }}page={{ pageCourante - 1 }}" class="pagination-btn">← Précédent</a>
    {% else %}
      <span class="pagination-btn pagination-btn--desactive">← Précédent</span>
    {% endif %}

    <span class="pagination-info">Page {{ pageCourante }} / {{ totalPages }}</span>

    {% if pageCourante < totalPages %}
      <a href="{{ urlBase }}{{ separateur }}page={{ pageCourante + 1 }}" class="pagination-btn">Suivant →</a>
    {% else %}
      <span class="pagination-btn pagination-btn--desactive">Suivant →</span>
    {% endif %}
  </nav>
{% endif %}
