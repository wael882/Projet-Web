{% extends 'base.html.twig' %}

{% block title %}Stagio — Modifier {{ etudiant.prenom }} {{ etudiant.nom }}{% endblock %}

{% block styles %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ base_url }}css/pages/pilote.css" />
{% endblock %}

{% block content %}
<div class="pilote-container">

  <a href="/pilote/etudiant?id={{ etudiant.id_etudiant }}" class="btn-retour">← Retour à la fiche</a>

  <div class="pilote-header">
    <div>
      <h1>Modifier l'étudiant</h1>
      <p>{{ etudiant.prenom }} {{ etudiant.nom }}</p>
    </div>
  </div>

  {% if error %}
    <div class="alert alert-error">{{ error }}</div>
  {% endif %}

  <div class="formulaire-carte" style="max-width:560px;">
    <form method="POST" action="/pilote/modifier-etudiant">
      <input type="hidden" name="id_etudiant" value="{{ etudiant.id_etudiant }}">

      <div class="formulaire-grille">
        <div>
          <label class="formulaire-label">Prénom <span style="color:var(--orange);">*</span></label>
          <input type="text" name="prenom" value="{{ etudiant.prenom }}" required class="saisie">
        </div>
        <div>
          <label class="formulaire-label">Nom <span style="color:var(--orange);">*</span></label>
          <input type="text" name="nom" value="{{ etudiant.nom }}" required class="saisie">
        </div>
      </div>

      <div class="formulaire-colonne">
        <label class="formulaire-label">Email <span style="color:var(--orange);">*</span></label>
        <input type="email" name="email" value="{{ etudiant.email }}" required class="saisie">
      </div>

      <div class="formulaire-colonne">
        <label class="formulaire-label">École</label>
        <input type="text" name="ecole" value="{{ etudiant.ecole }}" class="saisie">
      </div>

      <div class="formulaire-colonne">
        <label class="formulaire-label">Promotion</label>
        <input type="text" name="promotion" value="{{ etudiant.promotion }}" class="saisie">
      </div>

      <div class="formulaire-colonne" style="margin-bottom:2rem;">
        <label class="formulaire-label">Nouveau mot de passe</label>
        <input type="password" name="mot_de_passe" minlength="8" class="saisie">
        <p class="saisie-aide">Laisser vide pour ne pas modifier le mot de passe.</p>
      </div>

      <div class="formulaire-actions">
        <a href="/pilote/etudiant?id={{ etudiant.id_etudiant }}" class="btn-secondaire">Annuler</a>
        <button type="submit" class="btn-principal">Enregistrer</button>
      </div>

    </form>
  </div>

</div>
{% endblock %}
