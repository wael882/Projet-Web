{% extends 'base.html.twig' %}

{% block title %}Stagio - Mon profil{% endblock %}

{% block description %}content="Stagio - Mon profil"{% endblock %}

{% block styles %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ base_url }}css/pages/profil.css" />
{% endblock %}

{% block content %}
  <div class="profil-section">

    <div class="profile-header">
      <label for="avatar-input" class="profile-avatar-wrapper" title="Changer la photo">
        {% if etudiant.avatar %}
          <img src="{{ base_url }}{{ etudiant.avatar }}" alt="Avatar" class="profile-avatar-img" />
        {% else %}
          <div class="profile-avatar">
            {{ user.prenom|slice(0,1)|upper }}{{ user.nom|slice(0,1)|upper }}
          </div>
        {% endif %}
        <span class="avatar-overlay">Modifier</span>
      </label>
      <div>
        <h1>{{ user.prenom }} {{ user.nom }}</h1>
        <p>{{ user.role|capitalize }}</p>
      </div>
    </div>

    {% if success %}
      <p class="alert alert-success">{{ success }}</p>
    {% endif %}
    {% if error %}
      <p class="alert alert-error">{{ error }}</p>
    {% endif %}

    <form method="POST" action="/profil" enctype="multipart/form-data" class="profil-form">

      <input type="file" id="avatar-input" name="avatar" accept="image/jpeg,image/png,image/webp" class="avatar-input-hidden" />

      <p class="section-label">Informations personnelles</p>

      <div class="form-row">
        <div class="form-group">
          <label for="prenom">Prénom</label>
          <input type="text" id="prenom" name="prenom" value="{{ user.prenom }}" required />
        </div>
        <div class="form-group">
          <label for="nom">Nom</label>
          <input type="text" id="nom" name="nom" value="{{ user.nom }}" required />
        </div>
      </div>

      <div class="form-group">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" value="{{ user.email }}" required />
      </div>

      <hr class="divider" />

      <p class="section-label">Scolarité</p>

      <div class="form-row">
        <div class="form-group">
          <label for="promotion">Promotion</label>
          <input type="text" id="promotion" name="promotion" value="{{ etudiant.promotion ?? '' }}" placeholder="ex: BTS SIO 2025" />
        </div>
        <div class="form-group">
          <label for="statut_recherche_stage">Statut de recherche</label>
          <select id="statut_recherche_stage" name="statut_recherche_stage">
            <option value="">-- Sélectionner --</option>
            <option value="En recherche active" {% if etudiant.statut_recherche_stage == 'En recherche active' %}selected{% endif %}>En recherche active</option>
            <option value="Ouvert aux opportunités" {% if etudiant.statut_recherche_stage == 'Ouvert aux opportunités' %}selected{% endif %}>Ouvert aux opportunités</option>
            <option value="Stage trouvé" {% if etudiant.statut_recherche_stage == 'Stage trouvé' %}selected{% endif %}>Stage trouvé</option>
          </select>
        </div>
      </div>

      <hr class="divider" />

      <p class="section-label">Changer le mot de passe <span>(laisser vide pour ne pas modifier)</span></p>

      <div class="form-row">
        <div class="form-group">
          <label for="password">Nouveau mot de passe</label>
          <input type="password" id="password" name="password" />
        </div>
        <div class="form-group">
          <label for="password_confirm">Confirmer</label>
          <input type="password" id="password_confirm" name="password_confirm" />
        </div>
      </div>

      <div class="form-actions">
        <button type="submit">Enregistrer les modifications</button>
      </div>

    </form>

  </div>
{% endblock %}
