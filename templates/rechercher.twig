{% extends 'base.html.twig' %}

{% block title %}Stagio - Accueil{% endblock %}

{% block description %}content="Stagio - Acceuil"{% endblock %}

{% block content %}
    <div class="recherche-container">

      <form method="GET" action="/rechercher">
        <input type="text" name="motCle" value="{{ motCle }}" placeholder="Rechercher une offre ou une entreprise...">
        <button type="submit">Rechercher</button>
      </form>

      <div class="results-grid">
        {% for offre in offres %}
          <div class="recherche-item">
            <div class="recherche-item-titre">{{ offre.titre }}</div>
            <div class="recherche-item-desc">{{ offre.description }}</div>
            <div class="recherche-item-meta">{{ offre.date_offre }}</div>
            <div class="recherche-item-meta">{{ offre.duree_stage }}</div>
            <a href="/offre?id={{ offre.id_offre }}">Voir l'offre</a>

            {% if offre.id_offre in favorisIds %}
            <form method="POST" action="{{ base_url }}favoris/supprimer">
                <input type="hidden" name="id_offre" value="{{ offre.id_offre }}">
                <button type="submit">&#10084;</button>
            </form>
            {% else %}
            <form method="POST" action="{{ base_url }}favoris">
                <input type="hidden" name="id_offre" value="{{ offre.id_offre }}">
                <button type="submit">&#9825;</button>
            </form>
            {% endif %}
          </div>
        {% endfor %}
      </div>

      {% if pageCourante > 1 %}
      <a href="/rechercher?page={{ pageCourante - 1 }}&motCle={{ motCle }}">← Précédent</a>
      {% endif %}
      {% if pageCourante < totalPages %}
      <a href="/rechercher?page={{ pageCourante + 1 }}&motCle={{ motCle }}">Suivant →</a>
      {% endif %}

    </div>
{% endblock %}
