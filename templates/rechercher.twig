{% extends 'base.html.twig' %}

{% block title %}Stagio - Accueil{% endblock %}

{% block description %}content="Stagio - Acceuil"{% endblock %}

{% block content %}
    <section>
      <h2>Offres d'emploi</h2>
      <span>Chercher une offre:</span><br />
      <input type="search" placeholder="Chercher une offre" />

      <div class="card">
        <img src="" alt="Logo Thales" />
        <h3>Thales</h3>
        <p>Cannes - 06</p>
        <p>Durée du stage : 4 mois</p>
        <a href="{{ base_url }}identification">Voir l'offre</a>
        <!-- dois etre connecté pour acceder a l'ofre -->
      </div>

      <div class="card">
        <img src="" alt="Logo Aibus" />
        <h3>Aibus</h3>
        <p>Paris - 94</p>
        <p>Durée du stage : 6 mois</p>
        <a href="{{ base_url }}identification">Voir l'offre</a>
        <!-- dois etre connecté pour acceder a l'ofre -->
      </div>

      <div class="card">
        <img src="" alt="Logo Naval Group" />
        <h3>Naval Group</h3>
        <p>Nantes - 44</p>
        <p>Durée du stage : 3 mois</p>
        <a href="{{ base_url }}identification">Voir l'offre</a>
        <!-- dois etre connecté pour acceder a l'ofre -->
      </div>
    </section>

{% endblock %}
