{% extends 'base.html.twig' %}

{% block title %}Stagio - Accueil{% endblock %}

{% block description %}content="Stagio - Acceuil"{% endblock %}

{% block styles %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ base_url }}css/pages/rechercher.css" />
{% endblock %}

{% block content %}
    <div class="recherche-container">

      <form method="GET" action="/rechercher">

        <div class="barre-recherche-principale" style="position:relative;">
          <input type="text" name="motCle" id="motCle" value="{{ filtres.motCle }}" placeholder="Rechercher une offre, une entreprise..." autocomplete="off">
          <button type="submit">Rechercher</button>
          <ul id="suggestions-live" class="suggestions-live" hidden></ul>
        </div>

        <div class="filtres-grille">

          <div class="filtre-champ">
            <label for="titre">Titre du poste</label>
            <input type="text" id="titre" name="titre" value="{{ filtres.titre }}" placeholder="Tous les titres" list="liste-titres" autocomplete="off">
            <datalist id="liste-titres">
              {% for titre in titres %}
                <option value="{{ titre }}">
              {% endfor %}
            </datalist>
          </div>

          <div class="filtre-champ">
            <label for="entreprise">Entreprise</label>
            <input type="text" id="entreprise" name="entreprise" value="{{ filtres.entreprise }}" placeholder="Nom de l'entreprise" list="liste-entreprises" autocomplete="off">
            <datalist id="liste-entreprises">
              {% for entreprise in entreprises %}
                <option value="{{ entreprise.nom }}">
              {% endfor %}
            </datalist>
          </div>

          <div class="filtre-champ">
            <label for="competence">Compétence</label>
            <select id="competence" name="competence">
              <option value="">Toutes les compétences</option>
              {% for comp in competences %}
                <option value="{{ comp.libelle }}" {% if filtres.competence == comp.libelle %}selected{% endif %}>
                  {{ comp.libelle }}
                </option>
              {% endfor %}
            </select>
          </div>

          <div class="filtre-champ">
            <label for="remuneration_min">Rémunération min (€)</label>
            <input type="number" id="remuneration_min" name="remuneration_min" value="{{ filtres.remuneration_min }}" placeholder="0" min="0" step="50">
          </div>

          <div class="filtre-champ">
            <label for="remuneration_max">Rémunération max (€)</label>
            <input type="number" id="remuneration_max" name="remuneration_max" value="{{ filtres.remuneration_max }}" placeholder="Illimitée" min="0" step="50">
          </div>

        </div>

      </form>

      <div class="results-grid">
        {% for offre in offres %}
        
          <div class="recherche-item">
            <div class="recherche-item-titre">{{ offre.titre }}</div>
            <div class="recherche-item-entreprise"><a href="/entreprise?id={{ offre.id_entreprise }}">{{ offre.nom_entreprise }}</a></div>
            <div class="recherche-item-desc">{{ offre.description }}</div>
            <div class="recherche-item-meta">{{ offre.date_offre }}</div>
            <div class="recherche-item-meta">{{ offre.duree_stage }}</div>
            <a href="/offre?id={{ offre.id_offre }}">Voir l'offre</a>

            {% if user and user.role not in ['admin', 'pilote'] %}
              {% if offre.id_offre in favorisIds %}
              <form method="POST" action="{{ base_url }}favoris/supprimer" class="form-favori">
                  <input type="hidden" name="id_offre" value="{{ offre.id_offre }}">
                  <button type="submit">&#10084;</button>
              </form>
              {% else %}
              <form method="POST" action="{{ base_url }}favoris" class="form-favori">
                  <input type="hidden" name="id_offre" value="{{ offre.id_offre }}">
                  <button type="submit">&#9825;</button>
              </form>
              {% endif %}
            {% endif %}

          </div>
        {% endfor %}
      </div>

      {% set parametresFiltres = 'motCle=' ~ filtres.motCle ~ '&titre=' ~ filtres.titre ~ '&entreprise=' ~ filtres.entreprise ~ '&competence=' ~ filtres.competence ~ '&remuneration_min=' ~ filtres.remuneration_min ~ '&remuneration_max=' ~ filtres.remuneration_max %}
      {% if pageCourante > 1 %}
      <a href="/rechercher?page={{ pageCourante - 1 }}&{{ parametresFiltres }}">← Précédent</a>
      {% endif %}
      {% if pageCourante < totalPages %}
      <a href="/rechercher?page={{ pageCourante + 1 }}&{{ parametresFiltres }}">Suivant →</a>
      {% endif %}

    </div>

    <script>
  document.querySelectorAll('.form-favori').forEach(form => {
    form.addEventListener('submit', () => {
      sessionStorage.setItem('scrollY_recherche', window.scrollY);
    });
  });

  window.addEventListener('load', () => {
    const scrollY = sessionStorage.getItem('scrollY_recherche');
    if (scrollY !== null) {
      window.scrollTo(0, parseInt(scrollY, 10));
      sessionStorage.removeItem('scrollY_recherche');
    }
  });
</script>
{% endblock %}

